{
  "compileOnSave": false,
  "compilerOptions": {
    "baseUrl": ".",
    "outDir": "./dist/out-tsc",
    "sourceMap": true,
    "declaration": false,
    "experimentalDecorators": true,
    "useDefineForClassFields": true,
    "module": "es2022",
    "moduleResolution": "bundler",
    "importHelpers": true,
    "target": "ES2022",
    "lib": ["ES2022", "dom"],
    "strict": true,
    "skipLibCheck": true,
    "types": []
  }
}
